# ===== Настройки MAX-бота Сводки ЕДДС =====
# Скопируйте в .env.max и заполните. Файл .env.max в репозиторий НЕ коммитится.

# Токен MAX-бота (business.max.ru → ваш бот ЕДДС → Интеграция → Получить токен).
MAX_BOT_TOKEN=ВАШ_ТОКЕН_MAX_БОТА_ЕДДС

# Публичный адрес сайта на GitHub Pages.
PAGES_URL=https://aggasyas.github.io/svodka-eds

# Разрешённые MAX user_id (через запятую). Пусто = всем.
ALLOWED_IDS=

# Разрешённые групповые чаты (id через запятую). Бот должен быть админом группы.
ALLOWED_CHAT_IDS=

# Куда СЛАТЬ результат при файле из группы (ПЕРЕНАПРАВЛЕНИЕ).
# Пусто = отвечать в ту же группу. Заполняйте, только если хотите
# убрать ответ из группы и слать только в этот чат.
REPORT_CHAT_ID=

# ДОП. чат (обычно ваша ЛИЧКА): туда ДУБЛИРУЕТСЯ финальное
# сообщение со ссылками — ДОПОЛНИТЕЛЬНО к ответу в группе.
# Чтобы узнать свой chat_id: напишите боту в личку, см. инструкцию.
EXTRA_REPORT_CHAT_ID=

# Маскировать ПДн в публикуемых страницах (1 = да). По умолчанию 0.
MASK_PII=0

# Какие файлы принимать в группе. По умолчанию svodka*.docx:
# NAME_FILTER=svodka.*\.docx$

# (необязательно) Пути. Обычно менять не нужно.
# SITE_DIR=/opt/svodka/docs
# GIT_REPO_DIR=/opt/svodka

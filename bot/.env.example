# ===== Настройки бота сводок ЕДДС =====
# Скопируйте этот файл в .env и заполните своими значениями.

# Токен бота от @BotFather (обязательно)
BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Кому разрешено пользоваться ботом — ваши Telegram numeric id через запятую.
# Узнать свой id: напишите боту @userinfobot. Можно несколько: 11111111,22222222
ALLOWED_IDS=11111111

# Постоянный адрес сайта на GitHub Pages (без слэша в конце).
# Подставьте свой логин и имя репозитория.
PAGES_URL=https://aggasyas.github.io/svodka-eds

# --- Пути (обычно менять не нужно, заданы по умолчанию) ---
# Папка с кодом пайплайна (build_all.py и render_*.py). По умолчанию — родитель папки bot/.
# PIPELINE_DIR=/opt/svodka
# Папка, куда складывается готовый сайт.
# SITE_DIR=/opt/svodka/site
# Файл истории всех сводок.
# HISTORY=/opt/svodka/history.jsonl
# Папка git-репозитория, который пушится на GitHub Pages.
# GIT_REPO_DIR=/opt/svodka

# Маскировать персональные данные (1 — да, 0 — нет).
# Для публичного GitHub Pages ДОЛЖНО быть 1 — скрывает телефоны, ФИО,
# номера домов/квартир (населённые пункты/улицы и все цифры остаются).
MASK_PII=1
